{
  "manifest_version": 3,
  "name": "CommentAI - Résumé de commentaires",
  "version": "0.1.0",
  "description": "Résume automatiquement les commentaires YouTube et Reddit grâce aux API IA embarquées de Chrome (Summarizer, Translator, Language Detector).",

  "permissions": ["storage"],

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.reddit.com/*",
    "https://old.reddit.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": [
        "content-scripts/utils/dom-observer.js",
        "content-scripts/scrapers/youtube-scraper.js",
        "content-scripts/summarizer.js",
        "content-scripts/ui-injector.js",
        "content-scripts/main.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.reddit.com/r/*/comments/*",
        "https://old.reddit.com/r/*/comments/*"
      ],
      "js": [
        "content-scripts/utils/dom-observer.js",
        "content-scripts/scrapers/reddit-scraper.js",
        "content-scripts/summarizer.js",
        "content-scripts/ui-injector.js",
        "content-scripts/main.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  }
}
